# Variables de entorno para Google Sheets MCP Server

# REQUERIDO: URL de tu Google Apps Script desplegado
# Obtén esta URL después de desplegar tu Apps Script como Web App
# Ejemplo: https://script.google.com/macros/s/TU_SCRIPT_ID_AQUI/exec
APPS_SCRIPT_URL=

# OPCIONAL: Activar modo debug (muestra más información en logs)
# Valores: true o false
DEBUG=false
